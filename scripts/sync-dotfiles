#!/usr/bin/env bash
# Sync dotfiles repos to home directory.
#   DOTFILES_SYNC_REPOS       colon-separated list of repo paths (default: this repo)
#   DOTFILES_SYNC_SKIP        colon-separated list of target paths to skip
#   DOTFILES_SYNC_WHOLE_DIRS  colon-separated list of target paths to symlink as whole dirs
set -euo pipefail

_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

IFS=':' read -ra repos <<< "${DOTFILES_SYNC_REPOS:-$(dirname "$_SCRIPT_DIR")}"

skip_args=()
if [[ -n "${DOTFILES_SYNC_SKIP:-}" ]]; then
    IFS=':' read -ra skips <<< "$DOTFILES_SYNC_SKIP"
    for s in "${skips[@]}"; do
        skip_args+=(--skip "$s")
    done
fi

whole_dir_args=()
if [[ -n "${DOTFILES_SYNC_WHOLE_DIRS:-}" ]]; then
    IFS=':' read -ra whole_dirs <<< "$DOTFILES_SYNC_WHOLE_DIRS"
    for d in "${whole_dirs[@]}"; do
        whole_dir_args+=(--whole-dir "$d")
    done
fi

echo "Customize sync-dotfiles behavior by setting DOTFILES_SYNC_REPOS / DOTFILES_SYNC_SKIP / DOTFILES_SYNC_WHOLE_DIRS env vars."
(
    set -x
    exec deploy-dotfiles "${repos[@]}" "${skip_args[@]}" "${whole_dir_args[@]}" "$@"
)
