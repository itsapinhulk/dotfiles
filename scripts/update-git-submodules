#!/usr/bin/env bash
# Pull the latest commit for every submodule recursively.
set -euo pipefail

if [[ $# -eq 0 ]]; then
    echo "Usage: update-git-submodules <target-dir>" >&2
    echo "  GIT_SUBMODULES_UPDATE_SKIP  colon-separated list of submodule paths to skip" >&2
    exit 1
fi
TARGET="$1"

# Colon-separated list of submodule paths to skip (e.g. ext/foo:ext/bar)
GIT_SUBMODULES_UPDATE_SKIP="${GIT_SUBMODULES_UPDATE_SKIP:-}"
export GIT_SUBMODULES_UPDATE_SKIP

_sync_submodule() {
    local IFS=':'
    local skip
    for skip in ${GIT_SUBMODULES_UPDATE_SKIP}; do
        if [[ "$displaypath" == "$skip" ]]; then
            echo "Skipping $displaypath"
            return
        fi
    done

    echo "Syncing $displaypath..."
    git fetch origin
    if git symbolic-ref HEAD >/dev/null 2>&1; then
        git merge --ff-only FETCH_HEAD
    else
        git checkout FETCH_HEAD
    fi
}
export -f _sync_submodule

git -C "$TARGET" submodule foreach --recursive \
  "$(declare -f _sync_submodule); _sync_submodule"
