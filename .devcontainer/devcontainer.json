{
  "name": "Dotfiles Dev Environment",
  "runArgs": ["--hostname", "devct-dotfiles"],
  "build": {
    "dockerfile": "Dockerfile"
  },
  "workspaceFolder": "/repo/itsapinhulk/dotfiles",
  "workspaceMount": "source=${localWorkspaceFolder},target=${containerWorkspaceFolder},type=bind",
  "remoteUser": "devuser",
  "containerUser": "devuser",
  // Ensures the container workspace folder is owned by your user
  "updateRemoteUserUID": true,
  "mounts": [
      "source=claude-code-config,target=/home/devuser/.claude,type=volume",
      "type=volume,target=${containerWorkspaceFolder}/.jj"
  ],
  "containerEnv": {
      "CLAUDE_CONFIG_DIR": "/home/devuser/.claude"
  },
  "updateContentCommand": "sudo chown -R devuser:devuser ${containerWorkspaceFolder} || true"
}
